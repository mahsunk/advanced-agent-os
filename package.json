{
  "name": "advanced-agent-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace @advanced-agent-os/api",
    "dev:web": "npm run dev --workspace @advanced-agent-os/web",
    "build:web": "npm run build --workspace @advanced-agent-os/web",
    "check": "npm run build:web"
  },
  "engines": {
    "node": ">=20"
  }
}
